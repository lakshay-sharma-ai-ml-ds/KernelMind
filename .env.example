# OLLAMA_HOST=localhost
# OLLAMA_PORT=11434
# OLLAMA_MODEL=nvidia/nemotron-super
# OLLAMA_TEMPERATURE=0.7
# OLLAMA_MAX_TOKENS=2000
# OLLAMA_TIMEOUT=30
# OLLAMA_NUM_RETRIES=3
# OLLAMA_RETRY_DELAY=1.0

# ── How to use ────────────────────────────────────────────────────────────────
# 1. Copy this file to .env in the project root:
#        cp .env.example .env
#
# 2. Uncomment and edit any lines you want to change.
#    All values above are the defaults — you only need to set a variable
#    if you want to override the default.
#
# 3. Start Ollama (Docker):
#        bash scripts/setup_ollama.sh
#    Or manually:
#        docker run -d --name ollama -p 11434:11434 ollama/ollama
#        docker exec ollama ollama pull nvidia/nemotron-super
#
# 4. Verify everything works:
#        python scripts/check_ollama.py
#
# 5. Run the project:
#        python quickstart.py
#        python main.py
#
# ── Notes ─────────────────────────────────────────────────────────────────────
# OLLAMA_TIMEOUT    Increase this (e.g. 60) if first-run model loading is slow.
# OLLAMA_MODEL      Any Ollama-compatible model tag works (e.g. llama3, mistral).
# No API key is needed — inference runs entirely on your local machine via
# NVIDIA Nemotron Super.
